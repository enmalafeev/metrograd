; Метроград — демо симулятора поезда метро
; Godot 4.7

config_version=5

[application]

config/name="Метроград"
config/description="Демо симулятора поезда метро в стиле пиксель-арт"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

[input]

throttle_up={
"deadzone": 0.5,
"events": [{
"deadzone": 0.5,
"device": -1,
"keycode": 87,
"physical_keycode": 87,
"unicode": 119,
"type": "InputEventKey"
}]
}
throttle_down={
"deadzone": 0.5,
"events": [{
"deadzone": 0.5,
"device": -1,
"keycode": 83,
"physical_keycode": 83,
"unicode": 115,
"type": "InputEventKey"
}]
}
doors={
"deadzone": 0.5,
"events": [{
"deadzone": 0.5,
"device": -1,
"keycode": 32,
"physical_keycode": 32,
"unicode": 32,
"type": "InputEventKey"
}]
}

[rendering]

textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.05, 0.05, 0.07, 1)
